{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user in the system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification sent to a user.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["wish", "gift", "follow", "like"] },
        "user": { "type": "string" },
        "avatar": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "recipientId": { "type": "string" }
      },
      "required": ["type", "user", "avatar", "message", "createdAt", "isRead", "recipientId"]
    },
    "Post": {
      "title": "Post",
      "description": "A celebration post shared by a user.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "location": { "type": "string" },
        "celebrationType": { "type": "string" },
        "celebrantName": { "type": "string" },
        "feeling": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" }
      },
      "required": ["authorId", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles stored by UID."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Notifications for all users."
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Global feed posts."
    }
  }
}
