rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Primitives & Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Bootstrapped Admin
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == "passtyyaro302@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // -------------------------------------------------------------------------
    // Entity Validations
    // -------------------------------------------------------------------------

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'user', 'avatar', 'message', 'createdAt', 'isRead', 'recipientId']) &&
             data.keys().size() == 7 &&
             data.type in ['wish', 'gift', 'follow', 'like'] &&
             data.user is string && data.user.size() <= 100 &&
             data.avatar is string && data.avatar.size() <= 500 &&
             data.message is string && data.message.size() <= 500 &&
             data.createdAt == request.time &&
             data.isRead == false &&
             isValidId(data.recipientId);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time &&
             (!('content' in data) || (data.content is string && data.content.size() <= 2000)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 200)) &&
             (!('celebrationType' in data) || (data.celebrationType is string)) &&
             (!('authorName' in data) || (data.authorName is string)) &&
             (!('authorAvatar' in data) || (data.authorAvatar is string));
    }

    // -------------------------------------------------------------------------
    // Routes
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().recipientId);
      allow list: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isOwner(existing().recipientId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(existing().recipientId) || isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidPost(incoming());
      allow update: if (isOwner(existing().authorId) || isAdmin()) && isValidPost(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'location', 'likes']);
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
