{
  "expo": {
    "name": "BirthDayApp",
    "slug": "birthday-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
